# =============================================================================
# RAG0 Configuration — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# All settings can also be set in config.yaml (see config.yaml.example).
# Environment variables take precedence over YAML values.

# ---------------------------------------------------------------------------
# LLM (LiteLLM — supports OpenAI, DeepSeek, Anthropic, and 100+ providers)
# ---------------------------------------------------------------------------
# Set the API key for your LLM provider (required)
# DeepSeek:  DEEPSEEK_API_KEY=sk-xxx
# OpenAI:    OPENAI_API_KEY=sk-xxx
# Anthropic: ANTHROPIC_API_KEY=sk-ant-xxx
DEEPSEEK_API_KEY=your-api-key-here

# LLM model name (default: deepseek-chat)
RAG0_LLM__MODEL_NAME=deepseek-chat

# LLM base URL (default: https://api.deepseek.com)
RAG0_LLM__BASE_URL=https://api.deepseek.com

# LLM request timeout in seconds (default: 60)
RAG0_LLM__TIMEOUT=60

# Max retries on transient failures (default: 3)
RAG0_LLM__MAX_RETRIES=3

# ---------------------------------------------------------------------------
# Embedding Model
# ---------------------------------------------------------------------------
# HuggingFace model name or local path (required)
RAG0_EMBEDDING__MODEL_NAME=BAAI/bge-large-zh-v1.5

# Device: cpu, cuda, mps (default: auto-detect)
RAG0_EMBEDDING__DEVICE=auto

# Embedding vector dimension (auto-detected from model if not set)
RAG0_EMBEDDING__DIMENSIONS=1024

# ---------------------------------------------------------------------------
# Vector Store (Milvus)
# ---------------------------------------------------------------------------
# Milvus host (default: 127.0.0.1)
RAG0_VECTOR_STORE__HOST=127.0.0.1

# Milvus port (default: 19530)
RAG0_VECTOR_STORE__PORT=19530

# Milvus username (default: root)
RAG0_VECTOR_STORE__USER=root

# Milvus password (default: Milvus)
RAG0_VECTOR_STORE__PASSWORD=Milvus

# Enable TLS (default: false)
RAG0_VECTOR_STORE__SECURE=false

# ---------------------------------------------------------------------------
# Database (SQLite)
# ---------------------------------------------------------------------------
# Database URL (default: sqlite:///data/rag0.db)
RAG0_DATABASE__URL=sqlite:///data/rag0.db

# ---------------------------------------------------------------------------
# Text Splitting
# ---------------------------------------------------------------------------
# Chunk size for text splitting (default: 500)
RAG0_SPLITTER__CHUNK_SIZE=500

# Chunk overlap (default: 50)
RAG0_SPLITTER__CHUNK_OVERLAP=50

# Splitter name (default: ChineseRecursiveTextSplitter)
RAG0_SPLITTER__NAME=ChineseRecursiveTextSplitter

# ---------------------------------------------------------------------------
# Reranker
# ---------------------------------------------------------------------------
# Reranker model name or path
RAG0_RERANKER__MODEL_NAME=BAAI/bge-reranker-large

# Reranker type: cross-encoder | llm (default: cross-encoder)
RAG0_RERANKER__TYPE=cross-encoder

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
# API server host (default: 0.0.0.0)
RAG0_SERVER__HOST=0.0.0.0

# API server port (default: 7861)
RAG0_SERVER__PORT=7861

# CORS allowed origins (comma-separated, default: *)
RAG0_SERVER__CORS_ORIGINS=*

# ---------------------------------------------------------------------------
# Telemetry (Langfuse — optional)
# ---------------------------------------------------------------------------
# Enable Langfuse tracing (default: false)
RAG0_TELEMETRY__ENABLED=false

# Langfuse public key
RAG0_TELEMETRY__PUBLIC_KEY=

# Langfuse secret key
RAG0_TELEMETRY__SECRET_KEY=

# Langfuse host
RAG0_TELEMETRY__HOST=https://cloud.langfuse.com

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
RAG0_LOG_LEVEL=INFO

# Log format: json | console (default: console)
RAG0_LOG_FORMAT=console
